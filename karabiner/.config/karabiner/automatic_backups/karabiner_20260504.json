                "rules": [
                    {
                        "description": "Hyper and Meh Keys",
                        "manipulators": [
                            {
                                "description": "Right Command -> Hyper Key (Cmd+Ctrl+Opt+Shift)",
                                "from": {
                                    "key_code": "right_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "right_command" }],
                                "type": "basic"
                            },
                            {
                                "description": "Left/Right Option -> Meh Key (Ctrl+Opt+Shift)",
                                "from": {
                                    "key_code": "left_option",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_control", "left_option"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "left_option" }],
                                "type": "basic"
                            },
                            {
                                "description": "Right Option -> Meh Key (Ctrl+Opt+Shift)",
                                "from": {
                                    "key_code": "right_option",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_control", "left_option"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "right_option" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Vim Layer: HJKL (Arrows), UIOP (Jumps), NM,. (Selection Jumps)",
                        "manipulators": [
                            {
                                "description": "Set vim_layer to 1 when physical Left Command is held",
                                "from": {
                                    "key_code": "left_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "vim_layer",
                                            "value": 1
                                        }
                                    }
                                ],
                                "to_after_key_up": [
